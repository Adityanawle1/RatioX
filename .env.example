# Supabase Configuration (Required for database, portfolio sync, and auth)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Market Data API Keys (Optional, mock data fallback is used if missing)
